// RustGesture - Gesture Management UI
// WGestures-style settings dialog

import {
    Button,
    ComboBox,
    LineEdit,
    ScrollView,
} from "std-widgets.slint";

// Data model: represents an application entry in the sidebar
export struct AppItem {
    name: string,
    display-name: string,
    selected: bool,
}

// Data model: represents a gesture mapping row
export struct GestureItem {
    name: string,
    mnemonic: string,
    action-description: string,
    action-type: string,
}

// Helper component: clickable sidebar app row with hover effect
component AppRow inherits Rectangle {
    height: 32px;
    in property <bool> selected: false;
    in property <string> app-name: "";
    in property <string> display-name: "";
    callback clicked();

    background: selected ? #e8e8e8 : (ta.has-hover ? #f0f0f0 : transparent);

    ta := TouchArea {
        width: 100%;
        height: 100%;
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        width: 100%;
        height: 100%;
        padding-left: 12px;
        padding-right: 8px;
        spacing: 6px;

        // Selection indicator bar (wrapper stretches to full height, inner bar centered)
        Rectangle {
            width: 3px;

            Rectangle {
                width: 3px;
                height: 16px;
                y: (parent.height - 16px) / 2;
                background: root.selected ? #0078d4 : transparent;
                border-radius: 1px;
            }
        }

        // App icon placeholder (wrapper stretches to full height, inner icon centered)
        Rectangle {
            width: 18px;

            Rectangle {
                width: 18px;
                height: 18px;
                y: (parent.height - 18px) / 2;
                background: #cccccc;
                border-radius: 3px;

                Text {
                    text: root.app-name == "global" ? "G" : root.display-name;
                    font-size: 9px;
                    color: #666666;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    width: 100%;
                    height: 100%;
                }
            }
        }

        // App name text (stretches to full height, text centered via vertical-alignment)
        Text {
            text: root.display-name;
            font-size: 12px;
            color: #333333;
            vertical-alignment: center;
        }
    }

    // Row bottom border
    Rectangle {
        y: parent.height - 1px;
        width: 100%;
        height: 1px;
        background: #eeeeee;
    }
}

// Helper component: clickable gesture table row with hover and highlight
component GestureRow inherits Rectangle {
    height: 32px;
    in property <bool> highlighted: false;
    in property <string> col-name: "";
    in property <string> col-mnemonic: "";
    in property <string> col-action: "";
    callback clicked();

    background: highlighted ? #cce4f7 : (row-ta.has-hover ? #f5f5f5 : #ffffff);

    // Bottom border
    Rectangle {
        y: parent.height - 1px;
        width: 100%;
        height: 1px;
        background: #eeeeee;
    }

    row-ta := TouchArea {
        width: 100%;
        height: 100%;
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        width: 100%;
        height: 100%;
        spacing: 0px;

        // Column: Name
        Rectangle {
            horizontal-stretch: 1;
            height: 100%;

            Text {
                text: root.col-name;
                font-size: 12px;
                color: #333333;
                x: 10px;
                width: parent.width - 10px;
                height: 100%;
                vertical-alignment: center;
            }

            // Right border
            Rectangle {
                x: parent.width - 1px;
                width: 1px;
                height: 100%;
                background: #eeeeee;
            }
        }

        // Column: Mnemonic
        Rectangle {
            width: 100px;
            height: 100%;

            Text {
                text: root.col-mnemonic;
                font-size: 14px;
                color: #0078d4;
                x: 10px;
                width: parent.width - 10px;
                height: 100%;
                vertical-alignment: center;
            }

            // Right border
            Rectangle {
                x: parent.width - 1px;
                width: 1px;
                height: 100%;
                background: #eeeeee;
            }
        }

        // Column: Action
        Rectangle {
            horizontal-stretch: 1;
            height: 100%;

            Text {
                text: root.col-action;
                font-size: 12px;
                color: #555555;
                x: 10px;
                width: parent.width - 10px;
                height: 100%;
                vertical-alignment: center;
            }
        }
    }
}

export component GestureAppWindow inherits Window {
    title: "RustGesture 设置";
    preferred-width: 820px;
    preferred-height: 580px;
    background: #f5f5f5;
    default-font-family: "Microsoft YaHei";

    // --- Data Properties ---

    in-out property <[AppItem]> app-list: [
        { name: "global", display-name: "全局", selected: true },
    ];

    in-out property <[GestureItem]> gesture-list: [];

    in-out property <int> selected-gesture-index: -1;

    in-out property <string> action-detail: "";

    in-out property <[string]> action-types: [
        "键盘快捷键",
        "鼠标操作",
        "窗口管理",
        "运行程序",
    ];

    in-out property <int> current-action-type-index: 0;

    in-out property <string> current-app-name: "global";

    in-out property <string> param-section-title: "参数设置";

    // --- Callbacks ---

    callback app-selected(int);
    callback add-app-clicked();

    callback gesture-selected(int);
    callback add-gesture-clicked();
    callback remove-gesture-clicked(int);
    callback edit-gesture-clicked(int);

    callback action-type-changed(int);
    callback action-detail-changed(string);

    // --- Layout ---

    HorizontalLayout {
        padding: 0px;
        spacing: 0px;

        // ===== Left Sidebar =====
        Rectangle {
            width: 160px;
            background: #ffffff;

            // Right border separator
            Rectangle {
                x: parent.width - 1px;
                width: 1px;
                height: 100%;
                background: #e0e0e0;
            }

            VerticalLayout {
                width: 100%;
                height: 100%;
                padding: 0px;
                spacing: 0px;

                // Title area at top of sidebar
                Rectangle {
                    height: 40px;
                    background: #fafafa;

                    Text {
                        text: "应用程序";
                        font-size: 12px;
                        font-weight: 700;
                        color: #333333;
                        x: 12px;
                        width: parent.width - 12px;
                        height: 100%;
                        vertical-alignment: center;
                    }

                    Rectangle {
                        y: parent.height - 1px;
                        width: 100%;
                        height: 1px;
                        background: #e0e0e0;
                    }
                }

                // App list with scroll
                ScrollView {
                    VerticalLayout {
                        width: 100%;
                        padding: 0px;
                        spacing: 0px;

                        for app[idx] in root.app-list: AppRow {
                            selected: app.selected;
                            app-name: app.name;
                            display-name: app.display-name;
                            clicked => {
                                root.app-selected(idx);
                            }
                        }
                    }
                }

                // Spacer to push button to bottom
                Rectangle {
                    vertical-stretch: 1;
                    background: transparent;
                }

                // Add application button at bottom
                Rectangle {
                    height: 40px;
                    background: #fafafa;

                    Rectangle {
                        y: 0px;
                        width: 100%;
                        height: 1px;
                        background: #e0e0e0;
                    }

                    Rectangle {
                        x: 8px;
                        y: 6px;
                        width: parent.width - 16px;
                        height: 28px;
                        background: add-app-ta.has-hover ? #e8e8e8 : #ffffff;
                        border-radius: 3px;
                        border-width: 1px;
                        border-color: #d0d0d0;

                        add-app-ta := TouchArea {
                            width: 100%;
                            height: 100%;
                            clicked => {
                                root.add-app-clicked();
                            }
                        }

                        Text {
                            text: "+ 添加应用";
                            font-size: 12px;
                            color: #555555;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: 100%;
                            height: 100%;
                        }
                    }
                }
            }
        }

        // ===== Right Content Area =====
        VerticalLayout {
            padding: 0px;
            spacing: 0px;

            // --- Gesture List Section ---
            VerticalLayout {
                vertical-stretch: 0;
                padding: 12px;
                spacing: 8px;

                Text {
                    text: "手势列表";
                    font-size: 14px;
                    font-weight: 700;
                    color: #333333;
                }

                // Table header row
                Rectangle {
                    height: 30px;
                    background: #fafafa;
                    border-width: 1px;
                    border-color: #e0e0e0;
                    border-radius: 2px;

                    HorizontalLayout {
                        width: 100%;
                        height: 100%;
                        spacing: 0px;

                        Rectangle {
                            horizontal-stretch: 1;
                            height: 100%;

                            Text {
                                text: "名称";
                                font-size: 12px;
                                font-weight: 600;
                                color: #666666;
                                x: 10px;
                                width: parent.width - 10px;
                                height: 100%;
                                vertical-alignment: center;
                            }

                            Rectangle {
                                x: parent.width - 1px;
                                width: 1px;
                                height: 100%;
                                background: #e0e0e0;
                            }
                        }

                        Rectangle {
                            width: 100px;
                            height: 100%;

                            Text {
                                text: "助记符";
                                font-size: 12px;
                                font-weight: 600;
                                color: #666666;
                                x: 10px;
                                width: parent.width - 10px;
                                height: 100%;
                                vertical-alignment: center;
                            }

                            Rectangle {
                                x: parent.width - 1px;
                                width: 1px;
                                height: 100%;
                                background: #e0e0e0;
                            }
                        }

                        Rectangle {
                            horizontal-stretch: 1;
                            height: 100%;

                            Text {
                                text: "操作";
                                font-size: 12px;
                                font-weight: 600;
                                color: #666666;
                                x: 10px;
                                width: parent.width - 10px;
                                height: 100%;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                // Gesture rows (scrollable)
                ScrollView {
                    height: 180px;
                    vertical-scrollbar-policy: as-needed;

                    VerticalLayout {
                        width: 100%;
                        padding: 0px;
                        spacing: 0px;

                        for gesture[idx] in root.gesture-list: GestureRow {
                            highlighted: idx == root.selected-gesture-index;
                            col-name: gesture.name;
                            col-mnemonic: gesture.mnemonic;
                            col-action: gesture.action-description;
                            clicked => {
                                root.gesture-selected(idx);
                            }
                        }

                        if root.gesture-list.length == 0: Rectangle {
                            height: 60px;
                            background: transparent;

                            Text {
                                text: "暂无手势，点击下方按钮添加";
                                font-size: 12px;
                                color: #999999;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: 100%;
                                height: 100%;
                            }
                        }
                    }
                }

                // Action buttons row
                HorizontalLayout {
                    height: 32px;
                    spacing: 6px;

                    Button {
                        text: "+";
                        width: 60px;
                        clicked => {
                            root.add-gesture-clicked();
                        }
                    }

                    Button {
                        text: "-";
                        width: 60px;
                        enabled: root.selected-gesture-index >= 0;
                        clicked => {
                            root.remove-gesture-clicked(root.selected-gesture-index);
                        }
                    }

                    Button {
                        text: "编辑";
                        width: 70px;
                        enabled: root.selected-gesture-index >= 0;
                        clicked => {
                            root.edit-gesture-clicked(root.selected-gesture-index);
                        }
                    }
                }
            }

            // Separator
            Rectangle {
                height: 4px;

                Rectangle {
                    height: 1px;
                    y: 1px;
                    x: 12px;
                    width: parent.width - 24px;
                    background: #e0e0e0;
                }
            }

            // --- Parameter Editing Section ---
            VerticalLayout {
                vertical-stretch: 1;
                padding: 12px;
                spacing: 8px;

                Text {
                    text: root.param-section-title;
                    font-size: 14px;
                    font-weight: 700;
                    color: #333333;
                }

                // Action type selector row
                HorizontalLayout {
                    height: 32px;
                    spacing: 8px;

                    Text {
                        text: "执行操作:";
                        font-size: 12px;
                        color: #555555;
                        vertical-alignment: center;
                        width: 72px;
                    }

                    ComboBox {
                        model: root.action-types;
                        current-index: root.current-action-type-index;
                        enabled: root.selected-gesture-index >= 0;
                        selected(value) => {
                            root.action-type-changed(root.current-action-type-index);
                        }
                    }
                }

                // Action detail input row
                HorizontalLayout {
                    height: 32px;
                    spacing: 8px;

                    Text {
                        text: "快捷键:";
                        font-size: 12px;
                        color: #555555;
                        vertical-alignment: center;
                        width: 72px;
                    }

                    detail-edit := LineEdit {
                        text: root.action-detail;
                        enabled: root.selected-gesture-index >= 0;
                        placeholder-text: "例如: Ctrl+C";
                        edited => {
                            root.action-detail-changed(self.text);
                        }
                    }
                }

                Rectangle {
                    vertical-stretch: 1;
                    background: transparent;
                }

                Text {
                    text: "* 改动将自动保存并立即生效";
                    font-size: 11px;
                    color: #999999;
                }
            }
        }
    }
}
