// RustGesture - Gesture Management UI
// WGestures-style settings dialog

import {
    Button,
    ComboBox,
    LineEdit,
    ScrollView,
} from "std-widgets.slint";

// Data model: represents an application entry in the sidebar
export struct AppItem {
    name: string,
    display-name: string,
    selected: bool,
}

// Data model: represents a gesture mapping row
export struct GestureItem {
    name: string,
    mnemonic: string,
    action-type: string,
    action-params: string,
}

// Helper component: clickable sidebar app row with hover effect
component AppRow inherits Rectangle {
    height: 32px;
    in property <bool> selected: false;
    in property <string> app-name: "";
    in property <string> display-name: "";
    callback clicked();

    background: selected ? #e8e8e8 : (ta.has-hover ? #f0f0f0 : transparent);

    ta := TouchArea {
        width: 100%;
        height: 100%;
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        width: 100%;
        height: 100%;
        padding-left: 12px;
        padding-right: 8px;
        spacing: 6px;

        // Selection indicator bar
        Rectangle {
            width: 3px;

            Rectangle {
                width: 3px;
                height: 16px;
                y: (parent.height - 16px) / 2;
                background: root.selected ? #0078d4 : transparent;
                border-radius: 1px;
            }
        }

        // App icon placeholder
        Rectangle {
            width: 18px;

            Rectangle {
                width: 18px;
                height: 18px;
                y: (parent.height - 18px) / 2;
                background: #cccccc;
                border-radius: 3px;

                Text {
                    text: root.app-name == "global" ? "G" : root.display-name;
                    font-size: 9px;
                    color: #666666;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    width: 100%;
                    height: 100%;
                }
            }
        }

        // App name text
        Text {
            text: root.display-name;
            font-size: 12px;
            color: #333333;
            vertical-alignment: center;
        }
    }

    // Row bottom border
    Rectangle {
        y: parent.height - 1px;
        width: 100%;
        height: 1px;
        background: #eeeeee;
    }
}

// Table header row for gesture list
component TableHeader inherits Rectangle {
    width: 100%;
    height: 30px;
    background: #f0f0f0;

    // Bottom border
    Rectangle {
        y: parent.height - 1px;
        width: 100%;
        height: 1px;
        background: #d0d0d0;
    }

    HorizontalLayout {
        height: 100%;
        padding-left: 12px;
        padding-right: 12px;
        spacing: 0px;

        // 手势名称
        Text {
            text: "手势名称";
            font-size: 11px;
            font-weight: 700;
            color: #666666;
            vertical-alignment: center;
            horizontal-stretch: 2;
        }

        // 手势序列
        Text {
            text: "手势序列";
            font-size: 11px;
            font-weight: 700;
            color: #666666;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }

        // 操作类型
        Text {
            text: "操作类型";
            font-size: 11px;
            font-weight: 700;
            color: #666666;
            vertical-alignment: center;
            horizontal-stretch: 2;
        }

        // 参数
        Text {
            text: "参数";
            font-size: 11px;
            font-weight: 700;
            color: #666666;
            vertical-alignment: center;
            horizontal-stretch: 5;
        }
    }
}

// Gesture row: 4-column table layout
component GestureRow inherits Rectangle {
    height: 36px;
    in property <bool> highlighted: false;
    in property <string> col-name: "";
    in property <string> col-mnemonic: "";
    in property <string> col-action-type: "";
    in property <string> col-action-params: "";
    callback clicked();

    background: highlighted ? #cce4f7 : (row-ta.has-hover ? #f5f5f5 : #ffffff);

    // Bottom border
    Rectangle {
        y: parent.height - 1px;
        width: 100%;
        height: 1px;
        background: #eeeeee;
    }

    row-ta := TouchArea {
        width: 100%;
        height: 100%;
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        height: 100%;
        padding-left: 12px;
        padding-right: 12px;
        spacing: 0px;

        // 手势名称
        Text {
            text: root.col-name;
            font-size: 12px;
            color: #333333;
            vertical-alignment: center;
            horizontal-stretch: 2;
        }

        // 手势序列 (mnemonic arrows, blue)
        Text {
            text: root.col-mnemonic;
            font-size: 15px;
            color: #0078d4;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }

        // 操作类型
        Text {
            text: root.col-action-type;
            font-size: 12px;
            color: #555555;
            vertical-alignment: center;
            horizontal-stretch: 2;
        }

        // 参数
        Text {
            text: root.col-action-params;
            font-size: 12px;
            color: #333333;
            vertical-alignment: center;
            horizontal-stretch: 5;
        }
    }
}

// Custom radio button component
component RadioButton inherits Rectangle {
    height: 24px;
    in property <bool> checked: false;
    in property <string> label: "";
    callback toggled();

    HorizontalLayout {
        width: 100%;
        height: 100%;
        spacing: 4px;

        // Radio circle
        Rectangle {
            width: 16px;
            height: 16px;
            y: (parent.height - 16px) / 2;
            border-radius: 8px;
            border-width: 1px;
            border-color: root.checked ? #0078d4 : #999999;
            background: transparent;

            // Inner dot when checked
            if root.checked: Rectangle {
                width: 8px;
                height: 8px;
                x: (parent.width - 8px) / 2;
                y: (parent.height - 8px) / 2;
                border-radius: 4px;
                background: #0078d4;
            }
        }

        // Label text
        Text {
            text: root.label;
            font-size: 12px;
            color: root.checked ? #0078d4 : #555555;
            vertical-alignment: center;
        }
    }

    ta := TouchArea {
        width: 100%;
        height: 100%;
        clicked => { root.toggled(); }
    }
}

export component GestureAppWindow inherits Window {
    title: "RustGesture 设置";
    preferred-width: 1100px;
    preferred-height: 700px;
    min-width: 900px;
    min-height: 600px;
    background: #f5f5f5;
    default-font-family: "Microsoft YaHei";

    // --- Data Properties ---

    in-out property <[AppItem]> app-list: [
        { name: "global", display-name: "全局", selected: true },
    ];

    in-out property <[GestureItem]> gesture-list: [];

    in-out property <int> selected-gesture-index: -1;

    in-out property <string> action-detail: "";

    in-out property <[string]> action-types: [
        "键盘快捷键",
        "鼠标操作",
        "窗口管理",
        "运行程序",
    ];

    in-out property <int> current-action-type-index: 0;

    in-out property <string> current-app-name: "global";

    in-out property <string> param-section-title: "参数设置";

    // --- Edit Dialog Properties ---

    in-out property <bool> edit-dialog-visible: false;
    in-out property <string> edit-dialog-title: "添加手势";
    in-out property <string> edit-gesture-name: "";
    in-out property <string> edit-direction-display: "";
    in-out property <bool> edit-has-directions: false;
    in-out property <bool> edit-capturing: false;
    in-out property <int> edit-action-type-index: 0;
    in-out property <string> edit-action-detail: "";

    in-out property <[string]> window-commands: [
        "最小化",
        "最大化",
        "还原",
        "关闭窗口",
        "显示桌面",
    ];

    in-out property <int> edit-window-command-index: 0;

    in-out property <int> edit-trigger-button-index: 0;

    // --- Callbacks ---

    callback app-selected(int);
    callback add-app-clicked();

    callback gesture-selected(int);
    callback add-gesture-clicked();
    callback remove-gesture-clicked(int);
    callback edit-gesture-clicked(int);

    callback action-type-changed(int);
    callback action-detail-changed(string);

    // Edit dialog callbacks
    callback edit-capture-clicked();
    callback edit-clear-directions();
    callback edit-dialog-confirmed();
    callback edit-dialog-cancelled();

    // --- Layout ---

    HorizontalLayout {
        padding: 0px;
        spacing: 0px;

        // ===== Left Sidebar =====
        Rectangle {
            width: 160px;
            background: #ffffff;

            // Right border separator
            Rectangle {
                x: parent.width - 1px;
                width: 1px;
                height: 100%;
                background: #e0e0e0;
            }

            VerticalLayout {
                width: 100%;
                height: 100%;
                padding: 0px;
                spacing: 0px;

                // Title area at top of sidebar
                Rectangle {
                    height: 40px;
                    background: #fafafa;

                    Text {
                        text: "应用程序";
                        font-size: 12px;
                        font-weight: 700;
                        color: #333333;
                        x: 12px;
                        width: parent.width - 12px;
                        height: 100%;
                        vertical-alignment: center;
                    }

                    Rectangle {
                        y: parent.height - 1px;
                        width: 100%;
                        height: 1px;
                        background: #e0e0e0;
                    }
                }

                // App list with scroll
                ScrollView {
                    VerticalLayout {
                        width: 100%;
                        padding: 0px;
                        spacing: 0px;

                        for app[idx] in root.app-list: AppRow {
                            selected: app.selected;
                            app-name: app.name;
                            display-name: app.display-name;
                            clicked => {
                                root.app-selected(idx);
                            }
                        }
                    }
                }

                // Spacer to push button to bottom
                Rectangle {
                    vertical-stretch: 1;
                    background: transparent;
                }

                // Add application button at bottom
                Rectangle {
                    height: 40px;
                    background: #fafafa;

                    Rectangle {
                        y: 0px;
                        width: 100%;
                        height: 1px;
                        background: #e0e0e0;
                    }

                    Rectangle {
                        x: 8px;
                        y: 6px;
                        width: parent.width - 16px;
                        height: 28px;
                        background: add-app-ta.has-hover ? #e8e8e8 : #ffffff;
                        border-radius: 3px;
                        border-width: 1px;
                        border-color: #d0d0d0;

                        add-app-ta := TouchArea {
                            width: 100%;
                            height: 100%;
                            clicked => {
                                root.add-app-clicked();
                            }
                        }

                        Text {
                            text: "+ 添加应用";
                            font-size: 12px;
                            color: #555555;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: 100%;
                            height: 100%;
                        }
                    }
                }
            }
        }

        // ===== Right Content Area =====
        VerticalLayout {
            padding: 0px;
            spacing: 0px;

            // --- Gesture List Section ---
            VerticalLayout {
                vertical-stretch: 1;
                padding: 12px;
                spacing: 8px;

                // 标题
                Text {
                    text: "手势列表";
                    font-size: 14px;
                    font-weight: 700;
                    color: #333333;
                }

                // 表头
                TableHeader { }

                // 手势行（可滚动区域）
                ScrollView {
                    width: 100%;
                    vertical-stretch: 1;
                    vertical-scrollbar-policy: as-needed;

                    VerticalLayout {
                        width: 100%;
                        padding: 0px;
                        spacing: 0px;

                        for gesture[idx] in root.gesture-list: GestureRow {
                            highlighted: idx == root.selected-gesture-index;
                            col-name: gesture.name;
                            col-mnemonic: gesture.mnemonic;
                            col-action-type: gesture.action-type;
                            col-action-params: gesture.action-params;
                            clicked => {
                                root.gesture-selected(idx);
                            }
                        }

                        if root.gesture-list.length == 0: Rectangle {
                            height: 80px;
                            background: transparent;

                            Text {
                                text: "暂无手势，点击下方按钮添加";
                                font-size: 12px;
                                color: #999999;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: 100%;
                                height: 100%;
                            }
                        }
                    }
                }

                // 操作按钮行
                HorizontalLayout {
                    height: 32px;
                    spacing: 6px;

                    Button {
                        text: "添加";
                        width: 70px;
                        clicked => {
                            root.add-gesture-clicked();
                        }
                    }

                    Button {
                        text: "删除";
                        width: 70px;
                        enabled: root.selected-gesture-index >= 0;
                        clicked => {
                            root.remove-gesture-clicked(root.selected-gesture-index);
                        }
                    }

                    Button {
                        text: "编辑";
                        width: 70px;
                        enabled: root.selected-gesture-index >= 0;
                        clicked => {
                            root.edit-gesture-clicked(root.selected-gesture-index);
                        }
                    }
                }
            }
        }
    }

    // ===== Edit Gesture Dialog Overlay =====
    if root.edit-dialog-visible: Rectangle {
        width: 100%;
        height: 100%;
        background: #00000066;

        // Dialog box centered
        dialog-box := Rectangle {
            width: 400px;
            height: 480px;
            x: (parent.width - 400px) / 2;
            y: (parent.height - 480px) / 2;
            background: #ffffff;
            border-radius: 8px;
            border-width: 1px;
            border-color: #cccccc;

            VerticalLayout {
                width: 100%;
                height: 100%;
                padding: 0px;
                spacing: 0px;

                // Title bar with close button
                Rectangle {
                    height: 44px;

                    HorizontalLayout {
                        width: 100%;
                        height: 100%;
                        padding-left: 16px;
                        padding-right: 12px;
                        spacing: 0px;

                        Text {
                            text: root.edit-dialog-title;
                            font-size: 14px;
                            font-weight: 700;
                            color: #333333;
                            vertical-alignment: center;
                        }

                        Rectangle {
                            vertical-stretch: 1;
                            background: transparent;
                        }

                        // Close button
                        Rectangle {
                            width: 28px;
                            height: 28px;
                            y: (parent.height - 28px) / 2;
                            background: close-ta.has-hover ? #e0e0e0 : transparent;
                            border-radius: 4px;

                            close-ta := TouchArea {
                                width: 100%;
                                height: 100%;
                                clicked => {
                                    root.edit-dialog-cancelled();
                                }
                            }

                            Text {
                                text: "X";
                                font-size: 14px;
                                color: #666666;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: 100%;
                                height: 100%;
                            }
                        }
                    }

                    // Bottom border
                    Rectangle {
                        y: parent.height - 1px;
                        width: 100%;
                        height: 1px;
                        background: #e0e0e0;
                    }
                }

                // Dialog content
                VerticalLayout {
                    vertical-stretch: 1;
                    padding-left: 20px;
                    padding-right: 20px;
                    padding-top: 12px;
                    padding-bottom: 16px;
                    spacing: 10px;

                    // 手势名称
                    HorizontalLayout {
                        height: 32px;
                        spacing: 8px;

                        Text {
                            text: "手势名称:";
                            font-size: 12px;
                            color: #555555;
                            vertical-alignment: center;
                            width: 64px;
                        }

                        LineEdit {
                            text: root.edit-gesture-name;
                            edited => {
                                root.edit-gesture-name = self.text;
                            }
                        }
                    }

                    // 触发按键
                    HorizontalLayout {
                        height: 28px;
                        spacing: 8px;

                        Text {
                            text: "触发按键:";
                            font-size: 12px;
                            color: #555555;
                            vertical-alignment: center;
                            width: 64px;
                        }

                        HorizontalLayout {
                            height: 28px;
                            spacing: 16px;

                            RadioButton {
                                label: "中键";
                                checked: root.edit-trigger-button-index == 0;
                                toggled => { root.edit-trigger-button-index = 0; }
                            }
                            RadioButton {
                                label: "右键";
                                checked: root.edit-trigger-button-index == 1;
                                toggled => { root.edit-trigger-button-index = 1; }
                            }
                            RadioButton {
                                label: "X1";
                                checked: root.edit-trigger-button-index == 2;
                                toggled => { root.edit-trigger-button-index = 2; }
                            }
                            RadioButton {
                                label: "X2";
                                checked: root.edit-trigger-button-index == 3;
                                toggled => { root.edit-trigger-button-index = 3; }
                            }
                        }
                    }

                    // 手势序列
                    Text {
                        text: "手势序列:";
                        font-size: 12px;
                        color: #555555;
                    }

                    // 捕捉状态显示区域
                    HorizontalLayout {
                        height: 40px;
                        spacing: 8px;

                        Rectangle {
                            vertical-stretch: 1;
                            background: #f8f8f8;
                            border-radius: 4px;
                            border-width: 1px;
                            border-color: root.edit-capturing ? #ffcc80 : #e0e0e0;

                            Text {
                                text: root.edit-has-directions
                                    ? root.edit-direction-display
                                    : (root.edit-capturing ? "请用手势触发键画出方向..." : "点击右侧按钮捕捉手势");
                                font-size: root.edit-has-directions ? 16px : 12px;
                                color: root.edit-has-directions ? #0078d4 : (root.edit-capturing ? #e65100 : #bbbbbb);
                                x: 10px;
                                width: parent.width - 10px;
                                height: 100%;
                                vertical-alignment: center;
                            }
                        }

                        // 捕捉按钮
                        Rectangle {
                            width: 80px;
                            height: 36px;
                            y: (parent.height - 36px) / 2;
                            background: root.edit-capturing
                                ? (capture-ta.has-hover ? #c62828 : #d32f2f)
                                : (capture-ta.has-hover ? #1565c0 : #1976d2);
                            border-radius: 4px;

                            capture-ta := TouchArea {
                                width: 100%;
                                height: 100%;
                                clicked => {
                                    root.edit-capture-clicked();
                                }
                            }

                            Text {
                                text: root.edit-capturing ? "捕捉中..." : "开始捕捉";
                                font-size: 12px;
                                color: #ffffff;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: 100%;
                                height: 100%;
                            }
                        }

                        // 清除按钮
                        Rectangle {
                            width: 50px;
                            height: 36px;
                            y: (parent.height - 36px) / 2;
                            background: clear-seq-ta.has-hover ? #e0e0e0 : #f0f0f0;
                            border-radius: 4px;
                            border-width: 1px;
                            border-color: #d0d0d0;

                            clear-seq-ta := TouchArea {
                                width: 100%;
                                height: 100%;
                                clicked => {
                                    root.edit-clear-directions();
                                }
                            }

                            Text {
                                text: "清除";
                                font-size: 11px;
                                color: #555555;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: 100%;
                                height: 100%;
                            }
                        }
                    }

                    // Action type selector
                    HorizontalLayout {
                        height: 32px;
                        spacing: 8px;

                        Text {
                            text: "执行操作:";
                            font-size: 12px;
                            color: #555555;
                            vertical-alignment: center;
                            width: 64px;
                        }

                        ComboBox {
                            model: root.action-types;
                            current-index <=> root.edit-action-type-index;
                        }
                    }

                    // Action detail input (for non-Window types)
                    if root.edit-action-type-index != 2: HorizontalLayout {
                        height: 32px;
                        spacing: 8px;

                        Text {
                            text: "参数:";
                            font-size: 12px;
                            color: #555555;
                            vertical-alignment: center;
                            width: 64px;
                        }

                        LineEdit {
                            text: root.edit-action-detail;
                            edited => {
                                root.edit-action-detail = self.text;
                            }
                        }
                    }

                    // Window command selector (for Window type)
                    if root.edit-action-type-index == 2: HorizontalLayout {
                        height: 32px;
                        spacing: 8px;

                        Text {
                            text: "窗口命令:";
                            font-size: 12px;
                            color: #555555;
                            vertical-alignment: center;
                            width: 64px;
                        }

                        ComboBox {
                            model: root.window-commands;
                            current-index <=> root.edit-window-command-index;
                        }
                    }

                    // Spacer
                    Rectangle {
                        vertical-stretch: 1;
                        background: transparent;
                    }

                    // OK / Cancel buttons row
                    HorizontalLayout {
                        height: 36px;
                        spacing: 8px;
                        alignment: end;

                        // Cancel button
                        Rectangle {
                            width: 80px;
                            height: 32px;
                            background: cancel-ta.has-hover ? #e8e8e8 : #ffffff;
                            border-radius: 4px;
                            border-width: 1px;
                            border-color: #d0d0d0;

                            cancel-ta := TouchArea {
                                width: 100%;
                                height: 100%;
                                clicked => {
                                    root.edit-dialog-cancelled();
                                }
                            }

                            Text {
                                text: "取消";
                                font-size: 13px;
                                color: #555555;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: 100%;
                                height: 100%;
                            }
                        }

                        // OK button (primary)
                        Rectangle {
                            width: 80px;
                            height: 32px;
                            background: ok-ta.has-hover ? #106ebe : #0078d4;
                            border-radius: 4px;

                            ok-ta := TouchArea {
                                width: 100%;
                                height: 100%;
                                clicked => {
                                    root.edit-dialog-confirmed();
                                }
                            }

                            Text {
                                text: "确定";
                                font-size: 13px;
                                color: #ffffff;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: 100%;
                                height: 100%;
                            }
                        }
                    }
                }
            }
        }
    }
}
